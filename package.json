{
  "name": "archer-business-management",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Comprehensive business management platform with real-time collaboration, analytics, and PWA features",
  "keywords": [
    "business",
    "management",
    "collaboration",
    "analytics",
    "pwa",
    "react",
    "supabase"
  ],
  "author": "Archer Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "dev:tunnel": "concurrently \"npm run dev\" \"ngrok http 5173\"",
    "build": "tsc && vite build",
    "build:production": "tsc && vite build --config vite.config.production.ts",
    "build:analyze": "vite build --mode analyze",
    "build:report": "vite build --mode production && npm run analyze:bundle",
    "preview": "vite preview",
    "preview:production": "vite preview --config vite.config.production.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist node_modules/.vite",
    "clean:all": "rimraf dist node_modules/.vite .vite",
    "start": "npm run dev",
    "kill": "taskkill /f /im node.exe 2>nul || echo 'No Node processes found'",
    "restart": "npm run kill && npm run dev",
    "setup": "npm install && npm run dev",
    "server": "node server/index.cjs",
    "server:supabase": "node server/index-supabase.cjs",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "dev:supabase": "concurrently \"npm run server:supabase\" \"npm run dev\"",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "security:check": "npm audit && npm run security:fix",
    "performance:test": "lighthouse http://localhost:5173 --output=json --output-path=./lighthouse-report.json",
    "performance:report": "lighthouse http://localhost:5173 --view",
    "performance:analyze": "npm run build:analyze && npm run performance:test",
    "deploy:check": "npm run type-check && npm run lint && npm run build:production",
    "deploy:prepare": "npm run clean && npm run build:production",
    "deploy:test": "npm run build:production && npm run preview:production",
    "deploy:staging": "npm run deploy:check && echo 'Ready for staging deployment'",
    "deploy:production": "npm run deploy:check && echo 'Ready for production deployment'",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:logs": "supabase logs",
    "analyze:bundle": "npx vite-bundle-analyzer dist",
    "analyze:deps": "npx depcheck",
    "analyze:security": "npm audit && snyk test",
    "health:check": "curl -f http://localhost:5173 || exit 1",
    "health:full": "npm run health:check && npm run type-check && npm run lint",
    "ci:install": "npm ci",
    "ci:build": "npm run build:production",
    "ci:test": "npm run test:coverage",
    "ci:lint": "npm run lint && npm run format:check",
    "ci:security": "npm run security:check",
    "ci:all": "npm run ci:install && npm run ci:lint && npm run ci:test && npm run ci:build && npm run ci:security",
    "dev:enterprise": "concurrently \"npm run dev\" \"npm run db:status\" \"npm run health:check\"",
    "dev:monitor": "concurrently \"npm run dev\" \"npm run performance:test\"",
    "docs:generate": "typedoc src/**/*.ts --out docs",
    "docs:serve": "npx serve docs",
    "pwa:generate": "pwa-asset-generator ./src/assets/logo.png ./public/icons -i ./public/manifest.json",
    "pwa:validate": "pwa-asset-generator --help",
    "log:clear": "node -e \"localStorage.removeItem('app_logs'); console.log('Logs cleared')\"",
    "log:export": "node -e \"console.log(JSON.stringify(JSON.parse(localStorage.getItem('app_logs') || '[]'), null, 2))\"",
    "enterprise:setup": "npm run setup && npm run security:check && npm run format && npm run type-check",
    "enterprise:deploy": "npm run ci:all && npm run deploy:production",
    "enterprise:monitor": "npm run performance:analyze && npm run security:audit",
    
    "autosave:start": "node scripts/auto-save.js",
    "autosave:commit": "git add . && git commit -m \"Auto-save: $(date)\"",
    "autosave:push": "git push origin main",
    "autosave:backup": "npm run autosave:commit && npm run autosave:push",
    "github:setup": "git add . && git commit -m \"Initial commit\" && echo 'Ready to connect to GitHub'",
    "github:connect": "echo 'Run: git remote add origin YOUR_GITHUB_REPO_URL'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.4",
    "@hello-pangea/dnd": "^18.0.1",
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.50.4",
    "@tiptap/extension-code-block": "^2.23.1",
    "@tiptap/extension-color": "^2.23.1",
    "@tiptap/extension-highlight": "^2.23.1",
    "@tiptap/extension-image": "^2.23.1",
    "@tiptap/extension-link": "^2.23.1",
    "@tiptap/extension-table": "^2.23.1",
    "@tiptap/extension-table-cell": "^2.23.1",
    "@tiptap/extension-table-header": "^2.23.1",
    "@tiptap/extension-table-row": "^2.23.1",
    "@tiptap/extension-text-align": "^2.23.1",
    "@tiptap/extension-underline": "^2.23.1",
    "@tiptap/pm": "^2.23.1",
    "@tiptap/react": "^2.23.1",
    "@tiptap/starter-kit": "^2.23.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "gantt-task-react": "^0.3.9",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "simplebar-react": "^3.3.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.4",
    "autoprefixer": "^10.4.16",
    "compression": "^1.8.0",
    "concurrently": "^8.2.2",
    "cssnano": "^6.1.2",
    "depcheck": "^1.4.7",
    "eslint": "^8.55.0",
    "eslint-plugin-deprecation": "^1.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-security": "^1.7.1",
    "eslint-plugin-sonarjs": "^0.23.0",
    "eslint-plugin-typescript-sort-keys": "^3.3.0",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "lighthouse": "^12.7.1",
    "lint-staged": "^16.1.2",
    "playwright": "^1.40.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "pwa-asset-generator": "^8.0.5",
    "rimraf": "^5.0.10",
    "serve": "^14.2.1",
    "snyk": "^1.1260.0",
    "tailwindcss": "^3.3.6",
    "terser": "^5.43.1",
    "typedoc": "^0.25.4",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.0.3",
    "vite-bundle-analyzer": "^0.7.0",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
