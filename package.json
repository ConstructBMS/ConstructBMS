{
  "name": "constructbms",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Comprehensive business management platform with real-time collaboration, analytics, and PWA features",
  "keywords": [
    "business",
    "management",
    "collaboration",
    "analytics",
    "pwa",
    "react",
    "supabase"
  ],
  "author": "Archer Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist node_modules/.vite",
    "start": "npm run dev",
    "kill": "taskkill /f /im node.exe 2>nul || echo 'No Node processes found'",
    "restart": "npm run kill && timeout /t 2 /nobreak >nul && npm run dev",
    "setup": "npm install && npm run dev",
    "server": "node server/index.cjs",
    "server:supabase": "node server/index-supabase.cjs",
    "frontend": "npm run dev",
    "backend": "npm run server",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "dev:supabase": "concurrently \"npm run server:supabase\" \"npm run dev\"",
    "dev:concurrent": "concurrently \"npm run frontend\" \"npm run backend\"",
    "restart:full": "powershell -ExecutionPolicy Bypass -File restart.ps1",
    "restart:batch": "restart.bat",
    "rebuild": "npm run clean && npm install && npm run build",
    "rebuild:dev": "npm run clean && npm install && npm run dev:full",
    "logs": "powershell -ExecutionPolicy Bypass -File view-logs.ps1",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "health:check": "curl -f http://localhost:5173 || exit 1",
    "enterprise:setup": "npm run setup && npm run security:fix && npm run format && npm run type-check"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.4",
    "@hello-pangea/dnd": "^18.0.1",
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.50.4",
    "@tiptap/extension-code-block": "^2.23.1",
    "@tiptap/extension-color": "^2.23.1",
    "@tiptap/extension-highlight": "^2.23.1",
    "@tiptap/extension-image": "^2.23.1",
    "@tiptap/extension-link": "^2.23.1",
    "@tiptap/extension-table": "^2.23.1",
    "@tiptap/extension-table-cell": "^2.23.1",
    "@tiptap/extension-table-header": "^2.23.1",
    "@tiptap/extension-table-row": "^2.23.1",
    "@tiptap/extension-text-align": "^2.23.1",
    "@tiptap/extension-underline": "^2.23.1",
    "@tiptap/pm": "^2.23.1",
    "@tiptap/react": "^2.23.1",
    "@tiptap/starter-kit": "^2.23.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "gantt-task-react": "^0.3.9",
    "helmet": "^7.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.263.1",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "simplebar-react": "^3.3.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.4",
    "autoprefixer": "^10.4.16",
    "compression": "^1.8.0",
    "concurrently": "^8.2.2",
    "cssnano": "^6.1.2",
    "depcheck": "^1.4.7",
    "eslint": "^8.55.0",
    "eslint-plugin-deprecation": "^1.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-security": "^1.7.1",
    "eslint-plugin-sonarjs": "^0.23.0",
    "eslint-plugin-typescript-sort-keys": "^3.3.0",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "lighthouse": "^12.7.1",
    "lint-staged": "^16.1.2",
    "playwright": "^1.40.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "pwa-asset-generator": "^8.0.5",
    "rimraf": "^5.0.10",
    "serve": "^14.2.1",
    "snyk": "^1.1260.0",
    "tailwindcss": "^3.3.6",
    "terser": "^5.43.1",
    "typedoc": "^0.25.4",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.0.3",
    "vite-bundle-analyzer": "^0.7.0",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
