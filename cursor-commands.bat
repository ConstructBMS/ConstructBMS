@echo off
title Cursor IDE Commands - ConstructBMS
color 0E

echo.
echo ========================================
echo CURSOR IDE INTEGRATED TERMINAL COMMANDS
echo ========================================
echo.
echo Quick reference for starting servers in Cursor IDE.
echo.

echo ========================================
echo STEP-BY-STEP INSTRUCTIONS
echo ========================================
echo.
echo 1. Open Cursor IDE
echo 2. Open integrated terminal: Ctrl + `
echo 3. In first terminal tab, run: npm run dev
echo 4. Open new terminal tab: Ctrl + Shift + `
echo 5. In second terminal tab, run: npm run server
echo.

echo ========================================
echo SERVER URLs
echo ========================================
echo.
echo Frontend: http://localhost:5173
echo Backend: http://localhost:3001
echo.

echo ========================================
echo KEYBOARD SHORTCUTS
echo ========================================
echo.
echo Ctrl + `          - Open integrated terminal
echo Ctrl + Shift + `  - Open new terminal tab
echo Ctrl + Shift + 5  - Split terminal
echo Ctrl + W          - Close terminal tab
echo.

echo ========================================
echo COMMANDS TO COPY
echo ========================================
echo.
echo Frontend Server:
echo npm run dev
echo.
echo Backend Server:
echo npm run server
echo.
echo Stop Servers:
echo Ctrl + C (in each terminal tab)
echo.

echo ========================================
echo BENEFITS
echo ========================================
echo.
echo ✓ No separate windows
echo ✓ Integrated with Cursor IDE
echo ✓ Easy terminal tab switching
echo ✓ See logs alongside code
echo ✓ Better development workflow
echo.

pause 