# Development Environment Configuration
# Copy this to .env.local and update with your actual values

# Supabase Configuration (Development)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Application Configuration
VITE_APP_NAME=ConstructBMS Business Management
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Analytics Configuration
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_DEBUG=true

# PWA Configuration
VITE_PWA_ENABLED=true
VITE_PWA_NAME=ConstructBMS BMS
VITE_PWA_SHORT_NAME=ConstructBMS
VITE_PWA_THEME_COLOR=#3b82f6
VITE_PWA_BACKGROUND_COLOR=#ffffff

# Security Configuration
VITE_CSP_ENABLED=false
VITE_HSTS_ENABLED=false
VITE_SECURE_COOKIES=false

# Performance Configuration
VITE_CACHE_ENABLED=false
VITE_COMPRESSION_ENABLED=false
VITE_CDN_ENABLED=false

# Monitoring Configuration
VITE_ERROR_TRACKING_ENABLED=false
VITE_PERFORMANCE_MONITORING=false
VITE_HEALTH_CHECK_ENABLED=true

# API Configuration
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RATE_LIMIT=100

# File Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/*,application/pdf,text/*,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
VITE_STORAGE_BUCKET=constructbms-files

# Real-time Configuration
VITE_REALTIME_ENABLED=false
VITE_REALTIME_HEARTBEAT=30000
VITE_REALTIME_RECONNECT_ATTEMPTS=5

# Development Features (Enabled in Development)
VITE_DEV_TOOLS_ENABLED=true
VITE_DEBUG_MODE=true
VITE_MOCK_DATA_ENABLED=true 