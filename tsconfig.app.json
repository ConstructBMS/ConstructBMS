{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@contexts/*": ["src/contexts/*"],
      "@services/*": ["src/services/*"],
      "@utils/*": ["src/utils/*"],
      "@types/*": ["src/types/*"],
      "@hooks/*": ["src/hooks/*"]
    },

    /* Enhanced Linting - Relaxed for current codebase */
    "strict": true,
    "noUnusedLocals": false, // Disabled to reduce noise
    "noUnusedParameters": false, // Disabled to reduce noise
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false, // Disabled for compatibility
    "noPropertyAccessFromIndexSignature": false, // Disabled for compatibility
    "noUncheckedIndexedAccess": false, // Disabled for compatibility
    "noImplicitAny": false, // Disabled to allow 'any' types
    "noImplicitThis": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,

    /* Performance & Development */
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/.tsbuildinfo",
    "assumeChangesOnlyAffectDirectDependencies": true,
    "disableSourceOfProjectReferenceRedirect": true,
    "disableReferencedProjectLoad": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false, // Disabled to reduce noise
    "declaration": false, // Disabled for development
    "declarationMap": false, // Disabled for development
    "sourceMap": true,
    "removeComments": false,
    "importHelpers": true,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "verbatimModuleSyntax": false // Disabled for compatibility
  },
  "include": [
    "src/**/*",
    "vite.config.ts",
    "postcss.config.*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build", 
    "coverage",
    "**/*.test.ts",
    "**/*.spec.ts",
    "scripts/**/*"
  ]
}
